    "e2e": "playwright test",
    "gen:metadata": "node scripts/gen-client-metadata.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
