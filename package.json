{
  "name": "mothtrap",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "A network-map Bluesky client — Mastotron reborn",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
